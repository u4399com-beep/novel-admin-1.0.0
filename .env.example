# ============================================================
# Novel Management System - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ─── Database ────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL="file:./db/custom.db"
# Production (PostgreSQL) — set in .env via docker-compose:
# DATABASE_URL="postgresql://novel:password@postgres:5432/novel_admin"

# ─── App Config ──────────────────────────────────────────
SCRAPER_SERVICE_URL="http://localhost:3099"
NEXT_PUBLIC_APP_NAME="小说管理系统"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Authentication (REQUIRED) ───────────────────────────
NEXTAUTH_SECRET="change-this-to-a-random-string-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_USERNAME="admin"
# IMPORTANT: No default password. Must be explicitly set.
ADMIN_PASSWORD=""

# ─── Service-to-Service Auth (REQUIRED) ──────────────────
# Independent token for scraper-service <-> Next.js communication.
# Must be different from NEXTAUTH_SECRET. No fallback.
SCRAPER_SERVICE_TOKEN="change-this-to-another-random-string"

# ─── Database Provider ───────────────────────────────────
# "sqlite" for local development, "postgresql" for Docker production
# Only affects scraper-service queue. Prisma provider is set in schema.prisma.
DB_PROVIDER="sqlite"

# ─── Optional: External Services ─────────────────────────
# FIRECRAWL_API_KEY=""
# FIRECRAWL_API_URL="http://localhost:3002"
# AGENTQL_API_KEY=""
# AGENTQL_API_URL="https://api.agentql.com"
# CLOUD_BROWSER_PROVIDER="browserless"
# BROWSERLESS_API_KEY=""
# BROWSERLESS_API_URL=""
# STEEL_API_KEY=""
# STEEL_API_URL=""
# DEBUG="false"